---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Brand Spaces & Pop-ups — AXMEDIA" description="Temporäre und permanente Markenräume mit hoher Aufenthaltsqualität.">

<nav class="fixed top-0 left-0 right-0 bg-white/95 backdrop-blur z-50 border-b border-[#e5e5e5]">
  <div class="max-w-7xl mx-auto px-8 flex justify-between items-center h-20">
    <a href="/" class="font-semibold tracking-tight text-xl">AXMEDIA</a>
    <a href="/leistungen" class="text-sm hover:text-[#666]">← Leistungen</a>
  </div>
</nav>

<section class="pt-20 section max-w-4xl mx-auto px-8">
  <div class="text-[#666] text-sm tracking-[3px] mb-4">LEISTUNG 04</div>
  <h1 class="text-7xl font-semibold tracking-[-3px] leading-none mb-8">Brand Spaces<br>&amp; Pop-ups</h1>
  <p class="text-2xl text-[#555]">Temporäre und permanente Markenräume. Showrooms, Experience Stores und Pop-up-Konzepte mit hoher Aufenthaltsqualität und klarer Markeninszenierung.</p>
</section>

<section class="max-w-4xl mx-auto px-8 pb-24">
  <div class="grid md:grid-cols-3 gap-8 text-sm">
    <div>
      <div class="font-semibold mb-3">Kundennutzen</div>
      <ul class="space-y-1 text-[#555]">
        <li>Marke erlebbar machen</li>
        <li>Höhere Verweildauer der Besucher</li>
        <li>Stärkere emotionale Bindung</li>
        <li>Flexibel einsetzbar (temporär oder dauerhaft)</li>
      </ul>
    </div>
    <div>
      <div class="font-semibold mb-3">Was Sie bekommen</div>
      <ul class="space-y-1 text-[#555]">
        <li>Konzept &amp; Design</li>
        <li>Modulare Bauweise</li>
        <li>Technische Ausstattung</li>
        <li>Komplette Realisierung</li>
      </ul>
    </div>
    <div>
      <div class="font-semibold mb-3">Typische Ergebnisse</div>
      <p class="text-[#555]">Höhere Markenwahrnehmung und deutlich mehr qualifizierte Kontakte durch erlebbare Markenwelten.</p>
    </div>
  </div>
</section>

<section id="kontakt" class="section bg-[#111] text-white text-center">
  <h2 class="text-5xl font-semibold tracking-[-2px] mb-8">Möchten Sie Ihre Marke erlebbar machen?</h2>
  <a href="#kontakt" class="btn-primary">Kostenloses Gespräch vereinbaren</a>
</section>

</BaseLayout>
